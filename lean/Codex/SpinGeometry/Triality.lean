/-
  Codex.SpinGeometry.Triality

  Triality on Spin(8): the outer automorphism permuting the vector
  representation V and the two half-spinor representations
  Spin^+, Spin^-. Companion to the Master-tier unit `03.09.13 Triality
  on Spin(8) and exceptional Lie groups`.

  lean_status: partial — Mathlib has neither `Spin(n)` as a Lie group
  nor the spinor representations. The triality automorphism, octonion
  algebra, and exceptional Lie group constructions are all candidates
  for upstream contribution. We declare placeholder structures so the
  module compiles.
-/

import Mathlib.LinearAlgebra.CliffordAlgebra.Basic
import Mathlib.Algebra.Lie.Basic

namespace Codex.SpinGeometry.Triality

/-- Placeholder for the Spin(8) Lie group. Mathlib does not yet have
    a canonical Spin(n) as a Lie group with its double-cover map to
    SO(n). -/
structure Spin8 where
  carrier : Type
  group : Group carrier

/-- The vector representation V ≅ ℝ^8 of Spin(8). -/
def V : Type := Fin 8 → ℝ

/-- The two half-spinor representations Spin^± ≅ ℝ^8 of Spin(8). All
    three are 8-dimensional and pairwise non-isomorphic as abstract
    Spin(8)-representations, despite their underlying vector spaces
    being equal. -/
def SpinPlus : Type := Fin 8 → ℝ

def SpinMinus : Type := Fin 8 → ℝ

