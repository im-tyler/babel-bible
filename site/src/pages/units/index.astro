---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
import { SECTIONS, SECTION_BY_KEY, sectionLabel, sectionOrder } from "../../lib/sections";

const units = await getCollection("units");

type UnitEntry = (typeof units)[number];

// Group by frontmatter `section` field.
const grouped = new Map<string, UnitEntry[]>();
units.forEach((u) => {
  const key = u.data.section || "unsectioned";
  if (!grouped.has(key)) grouped.set(key, []);
  grouped.get(key)!.push(u);
});

const sections = Array.from(grouped.entries())
  .map(([key, list]) => ({
    key,
    label: sectionLabel(key),
    anchor: SECTION_BY_KEY.get(key)?.anchor ?? key,
    order: sectionOrder(key),
    units: list.sort((a, b) =>
      String(a.data.id).localeCompare(String(b.data.id))
    ),
  }))
  .sort((a, b) => a.order - b.order);
---

<Base title="Units" active="units">
  <div class="unit-list-page">
    <h1>All units</h1>
    <p style="color: var(--color-text-soft); margin-bottom: 2rem;">
      {units.length} units across {sections.length} sections. Filter by typing in the search box, or jump to a section below.
    </p>

    <nav class="filter-bar" aria-label="Section jump">
      {sections.map((s) => (
        <a href={`#${s.anchor}`} class="filter-pill">{s.label} <span style="opacity:0.55; font-size: 0.85em;">({s.units.length})</span></a>
      ))}
    </nav>

    <div class="filter-bar">
      <input
        type="text"
        id="unit-search"
        placeholder="Filter by id or title…"
        autocomplete="off"
      />
      <span style="color: var(--color-text-faint); font-size: 0.85rem;">
        <span id="match-count">{units.length}</span> matches
      </span>
    </div>

    {sections.map((s) => (
      <section class="section-block" id={s.anchor} data-section={s.key}>
        <h2>{s.label}</h2>
        <div class="section-meta">
          {s.units.length} {s.units.length === 1 ? "unit" : "units"}
        </div>
        <div class="unit-card-grid">
          {s.units.map((u) => (
            <a
              href={`/u/${u.data.id}`}
              class="unit-card"
              data-search={`${u.data.id} ${u.data.title}`.toLowerCase()}
            >
              <div class="unit-card-id">{u.data.id}</div>
              <div class="unit-card-title">{u.data.title}</div>
              <div class="unit-card-tiers">
                {(u.data.tiers_present || ["master"]).map((t: string) => (
                  <span class={`tier-badge tier-badge--${t}`}>{t.slice(0, 1).toUpperCase()}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>

  <script is:inline>
    (() => {
      const input = document.getElementById("unit-search");
      const counter = document.getElementById("match-count");
      if (!input || !counter) return;
      const cards = Array.from(document.querySelectorAll(".unit-card"));
      const sections = Array.from(document.querySelectorAll(".section-block"));

      input.addEventListener("input", () => {
        const q = input.value.trim().toLowerCase();
        let matched = 0;
        cards.forEach((c) => {
          const haystack = c.getAttribute("data-search") || "";
          const visible = !q || haystack.includes(q);
          c.style.display = visible ? "" : "none";
          if (visible) matched++;
        });
        sections.forEach((s) => {
          const anyVisible = Array.from(s.querySelectorAll(".unit-card")).some(
            (c) => c.style.display !== "none"
          );
          s.style.display = anyVisible ? "" : "none";
        });
        counter.textContent = String(matched);
      });
    })();
  </script>
</Base>
