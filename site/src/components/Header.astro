---
import TierToggle from "./TierToggle.tsx";

interface Props {
  tiersPresent?: ("beginner" | "intermediate" | "master")[];
  showTierToggle?: boolean;
  active?: string;
}

const { tiersPresent, showTierToggle = false, active = "" } = Astro.props;
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="brand"><span class="brand-mark">∮</span> Codex</a>
    <nav class="site-nav" aria-label="Primary">
      <a href="/units" class={active === "units" ? "active" : ""}>Units</a>
      <a href="/concepts" class={active === "concepts" ? "active" : ""}>Concepts</a>
      <a href="/about" class={active === "about" ? "active" : ""}>About</a>
    </nav>
    {showTierToggle && (
      <TierToggle client:load tiersPresent={tiersPresent} />
    )}
  </div>
</header>
