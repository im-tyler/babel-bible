---
import Header from "../components/Header.astro";
import "../styles/global.css";
import "katex/dist/katex.min.css";

interface Props {
  title: string;
  description?: string;
  tiersPresent?: ("beginner" | "intermediate" | "master")[];
  showTierToggle?: boolean;
  active?: string;
}

const {
  title,
  description = "Codex — a three-tier interactive curriculum from foundations to graduate mathematics and physics.",
  tiersPresent,
  showTierToggle = false,
  active = "",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Codex</title>
    <meta name="description" content={description} />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'%3E%3Ctext y='20' font-size='22' font-family='serif' fill='%235a3e2b'%3E%E2%88%AE%3C/text%3E%3C/svg%3E" />
  </head>
  <body>
    <Header tiersPresent={tiersPresent} showTierToggle={showTierToggle} active={active} />
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div>Codex — three-tier curriculum on Neutron · <a href="/about">about</a> · <a href="/units">units</a> · <a href="/concepts">concepts</a></div>
    </footer>
  </body>
</html>
